    {
      "parameters": {
        "jsCode": "// Collect all tagged slides and build an ordered URL array:\n// Front [0] → Content [1..N, sorted] → CTA [9999]\nconst allItems = $input.all();\n\nconst front = allItems.filter(i => i.json.slide_type === 'front');\nconst content = allItems\n  .filter(i => i.json.slide_type === 'content')\n  .sort((a, b) => (a.json.slide_order || 0) - (b.json.slide_order || 0));\nconst cta = allItems.filter(i => i.json.slide_type === 'cta');\n\nconst slideUrls = [\n  ...front.map(i => i.json.slide_url).filter(Boolean),\n  ...content.map(i => i.json.slide_url).filter(Boolean),\n  ...cta.map(i => i.json.slide_url).filter(Boolean),\n];\n\n// Get post_body from the LLM output (before image nodes replaced $json)\nlet postBody = '';\ntry {\n  postBody = $('Split Out').first().json.output.variations[0].post_body || '';\n} catch (e) {}\n\nreturn [{\n  json: {\n    carousel_id: $('Webhook').first().json.body.carousel_id,\n    post_body: postBody,\n    slide_urls: slideUrls,\n    slide_count: slideUrls.length,\n    success: slideUrls.length > 0,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
