# Supabase — get from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL — used in auth email redirect URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# n8n webhook — Airtable workflow path
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/create-carousel

# Airtable — get from airtable.com > Account > API
AIRTABLE_API_KEY=your-airtable-api-key

# Webhook secret — n8n sends this header to authenticate the generation-done callback
WEBHOOK_SECRET=your-secret-here

# App URL — used in redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gumroad — product permalinks (short slug from your Gumroad product URL)
# e.g. if your product URL is gumroad.com/l/abc123, the permalink is abc123
GUMROAD_PRODUCT_10=your-10-credit-product-permalink
GUMROAD_PRODUCT_20=your-20-credit-product-permalink
GUMROAD_PRODUCT_40=your-40-credit-product-permalink

# Gumroad — public storefront URLs shown as "Buy on Gumroad" links
NEXT_PUBLIC_GUMROAD_URL_10=https://yourstore.gumroad.com/l/your-10-credit-product
NEXT_PUBLIC_GUMROAD_URL_20=https://yourstore.gumroad.com/l/your-20-credit-product
NEXT_PUBLIC_GUMROAD_URL_40=https://yourstore.gumroad.com/l/your-40-credit-product
