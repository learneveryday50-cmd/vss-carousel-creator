# Supabase — get from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL — used in auth email redirect URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — get from Stripe Dashboard > Developers > API keys (use test keys for dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_APP_URL=http://localhost:3000
